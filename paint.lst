	                            ; Kalle Paint (NES, ASM6)
	                            
	                            ; --- Constants -----------------------------------------------------------------------------------
	                            
	                            ; Note: "VRAM buffer" = what to update in VRAM on next VBlank.
	                            
	                            ; RAM
	                            vram_buf_hi   equ $00    ; VRAM buffer - high bytes of addresses (16 bytes)
	                            vram_buf_lo   equ $10    ; VRAM buffer - low bytes of addresses (16 bytes)
	                            vram_buf_val  equ $20    ; VRAM buffer - values (16 bytes)
	                            user_palette     equ $30    ; user palette (16 bytes; each $00-$3f; offsets 4/8/12 are unused)
	                            vram_offset    equ $40    ; offset to name/attr table 0 and vram_copy (2 bytes, low first; 0-$3ff)
	                            vram_copy_addr equ $42    ; address in vram_copy (2 bytes, low first; vram_copy...vram_copy+$3ff)
	                            mode        equ $44    ; program mode: 0=sm brush, 1=lg brush, 2=attr edit, 3=pal edit
	                            runmain     equ $45    ; run main loop? (flag; only MSB is important)
	                            pad_status   equ $46    ; first joypad status (bits: A, B, select, start, up, down, left, right)
	                            prev_pad_status equ $47    ; first joypad status on previous frame
	                            vram_count    equ $48    ; number of entries in VRAM buffer (0-16)
	                            temp        equ $49    ; temporary
	                            delay_left   equ $4a    ; cursor move delay left (paint mode)
	                            brush_size   equ $4b    ; cursor type (paint mode; 0=small, 1=big)
	                            paint_color  equ $4c    ; paint color (paint mode; 0-3)
	                            cursor_x     equ $4d    ; cursor X position (paint/attribute edit mode; 0-63)
	                            cursor_y     equ $4e    ; cursor Y position (paint/attribute edit mode; 0-55)
	                            blink_timer  equ $4f    ; cursor blink timer (attribute/palette editor)
	                            pal_edit_cursor_pos equ $50    ; cursor position (palette editor; 0-3)
	                            pal_edit_subpal equ $51    ; selected subpalette (palette editor; 0-3)
	                            prev_mode   equ $52    ; previous mode (to return to after palette editor)
	                            active_subpalette equ $53 ; currently active subpalette (1-3)
	                            vram_ready  equ $54    ; VRAM buffer ready flag (1 = ready for NMI)
	                            cursor_color_dirty equ $55 ; cursor color needs VRAM update (paint mode)
	                            sprite_data     equ $0200  ; $100 bytes (see init_sprite_data for layout)
	                            vram_copy    equ $0300  ; $400 bytes (copy of name/attribute table 0; must be at $xx00)
	                            ; END RAM
	                            
	                            ; memory-mapped registers; see https://wiki.nesdev.org/w/index.php/PPU_registers
	                            ppu_ctrl     equ $2000
	                            ppu_mask     equ $2001
	                            ppu_status   equ $2002
	                            oam_addr     equ $2003
	                            ppu_scroll   equ $2005
	                            ppu_addr     equ $2006
	                            ppu_data     equ $2007
	                            dmcfreq     equ $4010
	                            oam_dma      equ $4014
	                            sndchn      equ $4015
	                            joypad1     equ $4016
	                            joypad2     equ $4017
	                            
	                            ; joypad bitmasks
	                            pad_a       equ 1<<7                     ; A
	                            pad_b       equ 1<<6                     ; B
	                            pad_select      equ 1<<5                     ; select
	                            pad_start      equ 1<<4                     ; start
	                            pad_up       equ 1<<3                     ; up
	                            pad_down       equ 1<<2                     ; down
	                            pad_left       equ 1<<1                     ; left
	                            pad_right       equ 1<<0                     ; right
	                            
	                            ; default user palette
	                            def_bg_color  equ $0f  ; background (all subpalettes)
	                            def_color_0a  equ $15  ; reds
	                            def_color_0b  equ $25
	                            def_color_0c  equ $35
	                            def_color_1a  equ $18  ; yellows
	                            def_color_1b  equ $28
	                            def_color_1c  equ $38
	                            def_color_2a  equ $1b  ; greens
	                            def_color_2b  equ $2b
	                            def_color_2c  equ $3b
	                            def_color_3a  equ $12  ; blues
	                            def_color_3b  equ $22
	                            def_color_3c  equ $32
	                            
	                            ; user interface colors
	                            pal_edit_bg_color  equ $0f  ; palette editor background (black)
	                            pal_edit_txt_color equ $30  ; palette editor text (white)
	                            blinkcol1   equ $00  ; blinking cursor 1
	                            blinkcol2   equ $10  ; blinking cursor 2 (gray)
	                            
	                            ; sprite tile indexes (note: hexadecimal digits "0"-"F" must start at $00)
	                            small_cursor_tile equ $10  ; small paint cursor
	                            large_cursor_tile  equ $11  ; large paint cursor
	                            attr_cursor_tile equ $12  ; corner of attribute cursor
	                            dotted_corner_tile equ $17 ; dotted corner for auto-attr indicator
	                            cover_tile   equ $13  ; cover (palette editor)
	                            pal_tile_1    equ $14  ; left  half of "Pal" (palette editor)
	                            pal_tile_2    equ $15  ; right half of "Pal" (palette editor)
	                            color_ind_tile  equ $16  ; color indicator (palette editor)
	                            
	                            ; misc
	                            blink_rate   equ 4      ; attribute/palette editor cursor blink rate (0=fastest, 7=slowest)
	                            das_delay       equ 15     ; frames to wait before auto-repeat kicks in
	                            nav_delay_sm    equ 2      ; nav repeat delay (sm brush)
	                            nav_delay_lg    equ 5      ; nav repeat delay (lg brush)
	                            nav_delay_ae    equ 11     ; nav repeat delay (attr editor)
	                            draw_delay_sm   equ 5      ; draw repeat delay (sm brush)
	                            draw_delay_lg   equ 11     ; draw repeat delay (lg brush)
	                            draw_delay_ae   equ 23     ; draw repeat delay (attr editor)
	                            v_scroll     equ 0      ; PPU vertical scroll value (VRAM $2000 is at the top of visible area)
	                            
	                            ; --- iNES header ---------------------------------------------------------------------------------
	                            
	                                        ; see https://wiki.nesdev.org/w/index.php/INES
	                                        base $0000
00000 4E 45 53 1A                           db "NES", $1a            ; file id
00004 01 01                                 db 1, 1                  ; 16 KiB PRG ROM, 8 KiB CHR ROM
00006 01 00                                 db %00000001, %00000000  ; NROM mapper, vertical name table mirroring
00008 00 00 00 00 00 00 00 00               pad $0010, $00           ; unused
00010                           
00010                           ; --- Start of PRG ROM ----------------------------------------------------------------------------
00010                           
00010                                       ; only use last 2 KiB of CPU address space
00010                                       base $c000
0C000 FF FF FF FF FF FF FF FF..             pad $f800, $ff
0F800                           
0F800                           ; --- Initialization and main loop ----------------------------------------------------------------
0F800                           
0F800                           macro wait_vblank
0F800                                       bit $2002  ; wait until next VBlank starts
0F800                           -           bit $2002
0F800                                       bpl -
0F800                           endm
0F800                           
0F800                           reset       ; initialize the NES; see https://wiki.nesdev.org/w/index.php/Init_code
0F800 78                                    sei             ; ignore IRQs
0F801 D8                                    cld             ; disable decimal mode
0F802 A2 40                                 ldx #%01000000
0F804 8E 17 40                              stx $4017     ; disable APU frame IRQ
0F807 A2 FF                                 ldx #$ff
0F809 9A                                    txs             ; initialize stack pointer
0F80A E8                                    inx
0F80B 8E 00 20                              stx $2000     ; disable NMI
0F80E 8E 01 20                              stx $2001     ; disable rendering
0F811 8E 10 40                              stx $4010     ; disable DMC IRQs
0F814 8E 15 40                              stx $4015      ; disable sound channels
0F817                           
0F817 2C 02 20 2C 02 20 10 FB               wait_vblank
0F81F                           
0F81F A9 00                                 lda #$00             ; clear zero page and vram_copy
0F821 AA                                    tax
0F822 95 00                     -           sta $00,x
0F824 9D 00 03                              sta $0300,x
0F827 9D 00 04                              sta $0300+$100,x
0F82A 9D 00 05                              sta $0300+$200,x
0F82D 9D 00 06                              sta $0300+$300,x
0F830 E8                                    inx
0F831 D0 EF                                 bne -
0F833                           
0F833 A2 0F                                 ldx #(16-1)        ; init user palette
0F835 BD 40 F9                  -           lda init_palette,x
0F838 95 30                                 sta $30,x
0F83A CA                                    dex
0F83B 10 F8                                 bpl -
0F83D                           
0F83D A2 5F                                 ldx #(24*4-1)      ; init sprite data
0F83F BD 60 F9                  -           lda init_sprite_data,x
0F842 9D 00 02                              sta $0200,x
0F845 CA                                    dex
0F846 10 F7                                 bpl -
0F848                           
0F848 A2 04                                 ldx #(1*4)       ; show impact box sprites (#1-#4)
0F84A A0 04                                 ldy #4
0F84C BD 60 F9                  -           lda init_sprite_data,x
0F84F 9D 00 02                              sta $0200,x
0F852 E8                                    inx
0F853 E8                                    inx
0F854 E8                                    inx
0F855 E8                                    inx
0F856 88                                    dey
0F857 D0 F3                                 bne -
0F859                           
0F859 A2 14                                 ldx #(5*4)       ; hide remaining sprites (#5-#63)
0F85B A0 3B                                 ldy #59
0F85D 20 9A FE                              jsr hide_sprites  ; X = first byte index, Y = count
0F860                           
0F860 A9 1E                                 lda #30         ; init misc vars
0F862 85 4D                                 sta $4d
0F864 A9 1A                                 lda #26
0F866 85 4E                                 sta $4e
0F868 A9 00                                 lda #0
0F86A 85 44                                 sta $44
0F86C 85 4B                                 sta $4b
0F86E A9 01                                 lda #1
0F870 85 4C                                 sta $4c
0F872 85 53                                 sta $53
0F874 85 55                                 sta $55
0F876                           
0F876 2C 02 20 2C 02 20 10 FB               wait_vblank
0F87E                           
0F87E A9 3F                                 lda #$3f           ; init PPU palette
0F880 8D 06 20                              sta $2006
0F883 A2 00                                 ldx #$00
0F885 8E 06 20                              stx $2006
0F888 BD 40 F9                  -           lda init_palette,x
0F88B 8D 07 20                              sta $2007
0F88E E8                                    inx
0F88F E0 20                                 cpx #32
0F891 D0 F5                                 bne -
0F893                           
0F893 A9 20                                 lda #$20     ; clear name/attribute table 0 ($400 bytes)
0F895 8D 06 20                              sta $2006
0F898 A9 00                                 lda #$00
0F89A 8D 06 20                              sta $2006
0F89D A0 04                                 ldy #4
0F89F AA                        --          tax
0F8A0 8D 07 20                  -           sta $2007
0F8A3 E8                                    inx
0F8A4 D0 FA                                 bne -
0F8A6 88                                    dey
0F8A7 D0 F6                                 bne --
0F8A9                           
0F8A9 2C 02 20                              bit $2002  ; reset ppu_addr/ppu_scroll latch
0F8AC A9 00                                 lda #$00       ; reset PPU address and set scroll
0F8AE 8D 06 20                              sta $2006
0F8B1 8D 06 20                              sta $2006
0F8B4 8D 05 20                              sta $2005
0F8B7 A9 00                                 lda #0
0F8B9 8D 05 20                              sta $2005
0F8BC                           
0F8BC 2C 02 20 2C 02 20 10 FB               wait_vblank
0F8C4                           
0F8C4 A9 88                                 lda #%10001000  ; NMI, 8*8-px sprites, pattern table 0 for BG and 1 for sprites,
0F8C6 8D 00 20                              sta $2000     ; 1-byte VRAM address auto-increment, name table 0
0F8C9                           
0F8C9 A9 1E                                 lda #%00011110  ; show BG & sprites on entire screen,
0F8CB 8D 01 20                              sta $2001     ; don't use R/G/B de-emphasis or grayscale mode
0F8CE                           
0F8CE 24 45                     mainloop    bit $45      ; the main loop
0F8D0 10 FC                                 bpl mainloop     ; wait until NMI routine has run
0F8D2 46 45                                 lsr $45      ; clear flag to prevent main loop from running until after next NMI
0F8D4                           
0F8D4 A9 00                                 lda #0
0F8D6 85 54                                 sta $54
0F8D8 85 48                                 sta $48
0F8DA                           
0F8DA A5 46                                 lda $46    ; store previous joypad status
0F8DC 85 47                                 sta $47
0F8DE                           
0F8DE A2 01                                 ldx #$01        ; read first joypad
0F8E0 86 46                                 stx $46   ; initialize; set LSB of variable to detect end of loop
0F8E2 8E 16 40                              stx $4016
0F8E5 CA                                    dex
0F8E6 8E 16 40                              stx $4016
0F8E9 18                        -           clc             ; read 8 buttons; each one = OR of two LSBs
0F8EA AD 16 40                              lda $4016
0F8ED 29 03                                 and #%00000011
0F8EF F0 01                                 beq +
0F8F1 38                                    sec
0F8F2 26 46                     +           rol $46
0F8F4 90 F3                                 bcc -
0F8F6                           
0F8F6 A9 3F                                 lda #$3f             ; tell NMI routine to update blinking cursor/bg in VRAM
0F8F8 85 00                                 sta $00+0
0F8FA                                       
0F8FA A5 44                                 lda $44             ; check if we are in attribute editor
0F8FC C9 02                                 cmp #2
0F8FE F0 13                                 beq blink_bg
0F900                           
0F900                                       ; Default: blinking cursor (Sprite Palette 0, Color 3)
0F900 A9 13                                 lda #(4*4+3)
0F902 85 10                                 sta $10+0
0F904 A2 00                                 ldx #$00
0F906 A5 4F                                 lda $4f
0F908 29 10                                 and #(1<<4)
0F90A F0 02                                 beq +
0F90C A2 10                                 ldx #$10
0F90E 86 20                     +           stx $20+0
0F910 4C 30 F9                              jmp blink_done
0F913                           
0F913                           blink_bg    ; Attribute Editor: flash cursor color ($3F13) with active subpalette color
0F913 A9 13                                 lda #$13
0F915 85 10                                 sta $10+0
0F917 A5 4F                                 lda $4f
0F919 29 10                                 and #(1<<4)
0F91B F0 07                                 beq +
0F91D                                       ; Phase 1: Neutral cursor color (Light Gray)
0F91D A9 10                                 lda #$10
0F91F 85 20                                 sta $20+0
0F921 4C 30 F9                              jmp blink_done
0F924                           +           ; Phase 2: Active subpalette color
0F924 A5 53                                 lda $53
0F926 0A                                    asl a
0F927 0A                                    asl a
0F928 18                                    clc
0F929 69 01                                 adc #1
0F92B AA                                    tax
0F92C B5 30                                 lda $30,x
0F92E 85 20                                 sta $20+0
0F930                           
0F930 A9 01                     blink_done  lda #1               ; we have one entry
0F932 85 48                                 sta $48
0F934                           
0F934 E6 4F                                 inc $4f  ; advance timer
0F936 20 C0 F9                              jsr jump_engine  ; run code for the program mode we're in
0F939                           
0F939 A9 01                                 lda #1               ; signal that buffer is ready for NMI
0F93B 85 54                                 sta $54
0F93D                           
0F93D 4C CE F8                              jmp mainloop
0F940                           
0F940                           init_palette ; initial palette
0F940                                       ; background (also the initial user palette)
0F940 0F 15 25 35                           db $0f, $15, $25, $35
0F944 0F 18 28 38                           db $0f, $18, $28, $38
0F948 0F 1B 2B 3B                           db $0f, $1b, $2b, $3b
0F94C 0F 12 22 32                           db $0f, $12, $22, $32
0F950                                       ; sprites
0F950                                       ; 2nd color in all subpalettes: palette editor background
0F950                                       ; 3rd color in all subpalettes: selected colors in palette editor
0F950                                       ; 4th color in 1st subpalette : all cursors
0F950                                       ; 4th color in 2nd subpalette : palette editor text
0F950 0F 0F 0F 15                           db $0f, $0f, $0f,  $15
0F954 0F 0F 15 30                           db $0f, $0f, $15, $30
0F958 0F 0F 25 00                           db $0f, $0f, $25,         $00
0F95C 0F 0F 35 30                           db $0f, $0f, $35, $30
0F960                           
0F960                           init_sprite_data ; initial sprite data (Y, tile, attributes, X for each sprite)
0F960                                       ; paint mode
0F960 FF 10 01 00                           db    $ff, $10, %00000001,    0  ; #0:  cursor
0F964                                       ; attribute editor / paint impact indicator
0F964 FF 12 00 00                           db    $ff, $12, %00000000,    0  ; #1:  cursor top left
0F968 FF 12 40 00                           db    $ff, $12, %01000000,    0  ; #2:  cursor top right
0F96C FF 12 80 00                           db    $ff, $12, %10000000,    0  ; #3:  cursor bottom left
0F970 FF 12 C0 00                           db    $ff, $12, %11000000,    0  ; #4:  cursor bottom right
0F974                                       ; palette editor
0F974 FF 11 00 E8                           db    $ff,  $11, %00000000, 29*8  ; #5:  cursor
0F978 AF 14 03 E0                           db 22*8-1,    $14, %00000011, 28*8  ; #6:  left  half of "Pal"
0F97C AF 15 03 E8                           db 22*8-1,    $15, %00000011, 29*8  ; #7:  right half of "Pal"
0F980 AF 00 03 F0                           db 22*8-1,         $00, %00000011, 30*8  ; #8:  subpalette number
0F984 B7 0C 03 E0                           db 23*8-1,         $0c, %00000011, 28*8  ; #9:  "C"
0F988 B7 00 03 E8                           db 23*8-1,         $00, %00000011, 29*8  ; #10: color number - 16s
0F98C B7 00 03 F0                           db 23*8-1,         $00, %00000011, 30*8  ; #11: color number - ones
0F990 BF 16 00 E8                           db 24*8-1,  $16, %00000000, 29*8  ; #12: color 0
0F994 C7 16 01 E8                           db 25*8-1,  $16, %00000001, 29*8  ; #13: color 1
0F998 CF 16 02 E8                           db 26*8-1,  $16, %00000010, 29*8  ; #14: color 2
0F99C D7 16 03 E8                           db 27*8-1,  $16, %00000011, 29*8  ; #15: color 3
0F9A0 BF 13 01 E0                           db 24*8-1,   $13, %00000001, 28*8  ; #16: cover (to left  of color 0)
0F9A4 BF 13 01 F0                           db 24*8-1,   $13, %00000001, 30*8  ; #17: cover (to right of color 0)
0F9A8 C7 13 01 E0                           db 25*8-1,   $13, %00000001, 28*8  ; #18: cover (to left  of color 1)
0F9AC C7 13 01 F0                           db 25*8-1,   $13, %00000001, 30*8  ; #19: cover (to right of color 1)
0F9B0 CF 13 01 E0                           db 26*8-1,   $13, %00000001, 28*8  ; #20: cover (to left  of color 2)
0F9B4 CF 13 01 F0                           db 26*8-1,   $13, %00000001, 30*8  ; #21: cover (to right of color 2)
0F9B8 D7 13 01 E0                           db 27*8-1,   $13, %00000001, 28*8  ; #22: cover (to left  of color 3)
0F9BC D7 13 01 F0                           db 27*8-1,   $13, %00000001, 30*8  ; #23: cover (to right of color 3)
0F9C0                           
0F9C0 A6 44                     jump_engine  ldx $44           ; jump engine (run one sub depending on program mode)
0F9C2 BD CB F9                              lda jump_table_hi,x  ; note: don't inline this sub
0F9C5 48                                    pha                ; push target address minus one, high byte first
0F9C6 BD CF F9                              lda jump_table_lo,x
0F9C9 48                                    pha
0F9CA 60                                    rts                ; pull address, low byte first; jump to that address plus one
0F9CB                           
0F9CB F9 F9 FB FD               jump_table_hi dh paint_mode-1, paint_mode-1, attr_editor-1, pal_editor-1  ; jump table - high bytes
0F9CF D2 D2 94 3D               jump_table_lo dl paint_mode-1, paint_mode-1, attr_editor-1, pal_editor-1  ; jump table - low bytes
0F9D3                           
0F9D3                           ; --- Paint mode (code label prefix "pm") ---------------------------------------------------------
0F9D3                           
0F9D3 A5 47                     paint_mode   lda $47  ; select/B/start logic
0F9D5 29 70                                 and #(1<<5|1<<6|1<<4)
0F9D7 D0 6C                                 bne pm_arrows     ; if any pressed on previous frame, ignore them all
0F9D9                           
0F9D9 A5 46                                 lda $46    ; if start pressed, switch to palette editor
0F9DB 29 10                                 and #1<<4
0F9DD F0 25                                 beq +
0F9DF A5 44                                 lda $44          ; save current mode
0F9E1 85 52                                 sta $52
0F9E3 A9 03                                 lda #3           ; mode 3 = palette editor
0F9E5 85 44                                 sta $44
0F9E7 A9 FF                                 lda #$ff         ; hide paint cursor sprite
0F9E9 8D 00 02                              sta $0200+0+0
0F9EC A2 04                                 ldx #(1*4)       ; hide impact box sprites (#1-#4)
0F9EE A0 04                                 ldy #4
0F9F0 20 9A FE                              jsr hide_sprites
0F9F3 A2 14                                 ldx #(5*4)       ; show palette editor sprites (#5-#23)
0F9F5 BD 60 F9                  -           lda init_sprite_data,x
0F9F8 9D 00 02                              sta $0200,x
0F9FB E8                                    inx
0F9FC E8                                    inx
0F9FD E8                                    inx
0F9FE E8                                    inx
0F9FF E0 60                                 cpx #(24*4)
0FA01 D0 F2                                 bne -
0FA03 60                                    rts              ; return to main loop
0FA04                           
0FA04 A5 46                     +           lda $46    ; if select pressed, switch to next mode
0FA06 29 20                                 and #1<<5
0FA08 F0 29                                 beq +
0FA0A A5 44                                 lda $44          ; check if we are in small or large brush mode
0FA0C F0 16                                 beq ++            ; if small (0), go to large (1)
0FA0E                           
0FA0E                                       ; we are in large brush mode (1), switch to attribute editor (2)
0FA0E A9 02                                 lda #2           ; mode 2 = attribute editor
0FA10 85 44                                 sta $44
0FA12 A9 FF                                 lda #$ff         ; hide paint cursor sprite
0FA14 8D 00 02                              sta $0200+0+0
0FA17 A9 3C                                 lda #%00111100   ; make cursor coordinates a multiple of four
0FA19 25 4D                                 and $4d
0FA1B 85 4D                                 sta $4d
0FA1D A9 3C                                 lda #%00111100
0FA1F 25 4E                                 and $4e
0FA21 85 4E                                 sta $4e
0FA23 60                                    rts              ; return to main loop
0FA24                           
0FA24 A9 01                     ++          lda #1           ; mode 1 = large brush
0FA26 85 44                                 sta $44
0FA28 85 4B                                 sta $4b
0FA2A 46 4D                                 lsr $4d      ; make coordinates even for large brush
0FA2C 06 4D                                 asl $4d
0FA2E 46 4E                                 lsr $4e
0FA30 06 4E                                 asl $4e
0FA32 60                                    rts
0FA33                           
0FA33 A5 46                     +           lda $46    ; if B pressed, increment paint color (0-3)
0FA35 29 40                                 and #1<<6
0FA37 F0 0C                                 beq pm_arrows
0FA39 A6 4C                                 ldx $4c
0FA3B E8                                    inx
0FA3C 8A                                    txa
0FA3D 29 03                                 and #%00000011
0FA3F 85 4C                                 sta $4c
0FA41 A9 01                                 lda #1
0FA43 85 55                                 sta $55
0FA45                           
0FA45 A5 46                     pm_arrows    lda $46    ; arrow logic
0FA47 29 0F                                 and #(1<<3|1<<2|1<<1|1<<0)
0FA49 F0 0E                                 beq pm_no_arrows
0FA4B                                       
0FA4B AA                                    tax               ; save current arrow status
0FA4C A5 47                                 lda $47
0FA4E 29 0F                                 and #(1<<3|1<<2|1<<1|1<<0)
0FA50 D0 0B                                 bne pm_repeat     ; if any arrows were already held, jump to repeat logic
0FA52                                       
0FA52                                       ; Fresh press (DAS)
